# ─── Database ───────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# LOCAL dev:  postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/ai_notes_db
# DOCKER:     postgresql://postgres:YOUR_PASSWORD@postgres:5432/ai_notes_db  (auto-set by docker-compose)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/ai_notes_db"

# Postgres credentials — used by docker-compose to create the DB
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_PASSWORD
POSTGRES_DB=ai_notes_db

# ─── Redis ───────────────────────────────────────────────────────────────────
# LOCAL dev:  redis://127.0.0.1:6379
# DOCKER:     redis://redis:6379              (auto-set by docker-compose)
REDIS_URL=redis://127.0.0.1:6379

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Auth ───────────────────────────────────────────────────────────────────
# Use a cryptographically random 256-bit value in production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── Google Gemini AI ────────────────────────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
